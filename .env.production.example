# =============================================================================
# .env.production.example — Template para PRODUÇÃO
# Copie para `.env` no servidor de produção e preencha os segredos.
# Banco de dados: MySQL nativo no host (NÃO usar container).
# =============================================================================

APP_NAME="Instituto Alves Neves"
APP_ENV=production
APP_KEY=                                  # gerar: php artisan key:generate
APP_DEBUG=false
APP_URL=https://admin.institutoalvesneves.com.br

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# -----------------------------------------------------------------------------
# Painéis Filament — vinculam cada panel ao seu subdomínio
# -----------------------------------------------------------------------------
ADMIN_PANEL_DOMAIN=admin.institutoalvesneves.com.br
PORTAL_PANEL_DOMAIN=portal.institutoalvesneves.com.br

# -----------------------------------------------------------------------------
# Banco de dados — MySQL nativo no host
# host.docker.internal aponta para o host (Linux: requer extra_hosts no compose)
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=host.docker.internal
DB_PORT=3306
DB_DATABASE=isabelle
DB_USERNAME=isabelle
DB_PASSWORD=__defina_uma_senha_forte__

# -----------------------------------------------------------------------------
# Sessão & Cookies
# - SESSION_DOMAIN ficar em branco/null: cada subdomínio armazena seu próprio
#   cookie, evitando conflito entre /admin e /portal no mesmo navegador.
# - SESSION_COOKIE é o nome BASE; cada panel sobrescreve via middleware
#   (isabelle_admin_session / isabelle_portal_session).
# - SESSION_SECURE_COOKIE=true exige HTTPS (obrigatório em prod).
# -----------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_COOKIE=isabelle_session

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=smtp.seuprovedor.com.br
MAIL_PORT=587
MAIL_USERNAME=__usuario__
MAIL_PASSWORD=__senha__
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@institutoalvesneves.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# UID/GID do usuário do host — DEVEM bater com o dono dos arquivos no host
# para evitar problemas de permissão em bind-mounts.
# Verifique no host com: id
# Na VPS atual: uid=1001(ricelli) gid=1001(ricelli)
# -----------------------------------------------------------------------------
APP_UID=1001
APP_GID=1001
APP_USER=ricelli

VITE_APP_NAME="${APP_NAME}"
