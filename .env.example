APP_NAME="Instituto Alves Neves"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://admin.institutoalvesneves.local:8006

# -----------------------------------------------------------------------------
# Subdomínios dos painéis Filament
# Local:  admin.institutoalvesneves.local / portal.institutoalvesneves.local
# Prod:   admin.institutoalvesneves.com.br / portal.institutoalvesneves.com.br
# Adicione em /etc/hosts (Linux/WSL) ou C:\Windows\System32\drivers\etc\hosts:
#   127.0.0.1  admin.institutoalvesneves.local
#   127.0.0.1  portal.institutoalvesneves.local
# -----------------------------------------------------------------------------
ADMIN_PANEL_DOMAIN=admin.institutoalvesneves.local
PORTAL_PANEL_DOMAIN=portal.institutoalvesneves.local

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_ROOT_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# UID/GID/usuário do host para o build do container Docker (bind-mount).
# Verifique no host com: id
APP_UID=1000
APP_GID=1000
APP_USER=ricelli
